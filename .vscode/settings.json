{
  "python.defaultInterpreterPath": "${workspaceFolder}/pipeline/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.cwd": "${workspaceFolder}/pipeline",
  "python.testing.pytestArgs": ["tests"],
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true
  }
}
